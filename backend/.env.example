# === 매매신호 백엔드 환경변수 예시 ===
# 전부 optional. 비워두면 각 기능이 폴백으로 동작하거나 스킵됨.
# 실제 키는 .env 에만 두고 git에 커밋하지 말 것.

# --- 저장 계층 ---
# Supabase 설정 시 SupabaseStore 사용, 없으면 로컬 SQLite (DB_PATH)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
DB_PATH=./richman.db

# --- API 인증 (설정 시에만 X-API-Key 헤더 강제) ---
API_KEY=

# --- 거시 데이터 ---
# FRED 공식 API 키 (없으면 fredgraph CSV 폴백 — 키 불필요)
FRED_API_KEY=
# 한국은행 ECOS 키 (없으면 KR 금리는 미국 금리로 대체 + degraded 표시)
ECOS_API_KEY=

# --- KIS Developers (한국투자증권 OpenAPI) ---
# 없으면 한국 시세도 yfinance(.KS 티커) 폴백
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT=

# --- 뉴스 감성 ---
# Alpha Vantage NEWS_SENTIMENT (무료 25 req/day — 일 1회 배치에 충분)
ALPHAVANTAGE_API_KEY=
# 한국 뉴스 감성 (KR-FinBert-SC) — 통합 전까지 false 유지
NEWS_KR_ENABLED=false

# --- 뉴스 요약 (Claude Haiku, 표시용) ---
ANTHROPIC_API_KEY=
